{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestrated-squad.dev/schemas/workflow.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "phases", "max_cycles", "entrypoints"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^squad-[a-z]+$" },
    "phases": { "type": "array", "minItems": 1, "items": { "enum": ["initialized", "requirements", "requirements_review", "design", "planned", "implementation", "deterministic_checks", "review", "test_authoring", "verification", "ready_to_finish", "complete", "blocked"] } },
    "max_cycles": { "type": "integer", "minimum": 1, "maximum": 2 },
    "entrypoints": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^squad-" } }
  }
}
