{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestrated-squad.dev/schemas/state.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "workflow", "status", "phase", "next_action", "cycle", "max_cycles", "updated_at"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "workflow": { "type": "string", "pattern": "^squad-" },
    "status": { "enum": ["active", "blocked", "complete"] },
    "phase": { "type": "string", "minLength": 1 },
    "next_action": { "type": "string", "minLength": 1 },
    "cycle": { "type": "integer", "minimum": 0 },
    "max_cycles": { "type": "integer", "minimum": 1, "maximum": 2 },
    "updated_at": { "type": "string", "format": "date-time" },
    "artifacts": { "type": "object", "additionalProperties": { "type": "string" } },
    "reservations": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } }
  }
}
