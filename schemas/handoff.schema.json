{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestrated-squad.dev/schemas/handoff.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "status", "next_agent", "decisions", "open_questions"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "next_agent": { "type": "string", "minLength": 1 },
    "decisions": { "type": "array", "items": { "type": "object", "required": ["id", "decision"], "properties": { "id": { "type": "string" }, "decision": { "type": "string" } } } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "commands": { "type": "array", "items": { "type": "string" } }
  }
}
